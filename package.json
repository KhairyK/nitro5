    "node-addon-api": "^8.3.0",
    "ora": "^8.0.1",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "vite": "^6.0.0"
  }, 
  "devDependencies": {
    "node-gyp": "12.2.0"
  }
}
